{
  "crons": [
    {
      "path": "/api/admin/cleanup-payments",
      "schedule": "0 */12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(mp4|webm|ogg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
